# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/rydo

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=change_this_too_to_another_random_string
REFRESH_TOKEN_EXPIRES_IN=30d

# CORS (comma separated; * allows all for local dev)
CORS_ORIGINS=*

# AI / OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ML prediction microservice
ML_SERVICE_URL=http://127.0.0.1:8000
